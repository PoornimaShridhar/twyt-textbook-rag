## Copy this file to `.env` and fill values before running the app

# OpenAI API key (optional; used by OpenAI-based embeddings/LLMs)
OPENAI_API_KEY=

# Ollama self-hosted base URL (e.g., http://localhost:11434)
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3

# Tavily / web search API key (optional)
TAVILY_API_KEY=

# Chroma client storage path
CHROMA_CLIENT_PATH=Collections_new_2
DEFAULT_COLLECTION_NAME=text_Collection_3

# Misc
RESULTS_FOLDER=results
