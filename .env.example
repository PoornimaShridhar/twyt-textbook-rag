## Copy this file to `.env` and fill values before running the app

# Groq API key
GROQ_API_KEY=

# Groq model settings
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# Optional legacy settings kept for reference only:
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3
# TAVILY_API_KEY=

# Chroma client storage path
CHROMA_CLIENT_PATH=Collections_new_2
DEFAULT_COLLECTION_NAME=text_Collection_3

# Misc
RESULTS_FOLDER=results
